# ═══════════════════════════════════════════
# Da Enzo API – Umgebungsvariablen
# Kopiere diese Datei als .env und passe an
# ═══════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (UNBEDINGT ÄNDERN in Produktion!)
JWT_SECRET=BITTE_AENDERN_min_32_zeichen_langes_geheimnis
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Datenbank
DB_PATH=./data/enzo.db

# Website JSON-Export Pfad
WEBSITE_PATH=/var/www/enzo

# CORS (kommasepariert, z.B. für DEV und PROD)
CORS_ORIGINS=https://www.da-enzo-muenchen.de,https://dev.da-enzo-muenchen.de,https://admin.da-enzo-muenchen.de,http://localhost:5173

# E-Mail (SMTP) – optional, ohne SMTP werden Mails übersprungen
SMTP_HOST=mail.your-server.de
SMTP_PORT=587
SMTP_USER=info@da-enzo-muenchen.de
SMTP_PASS=DEIN_PASSWORT
SMTP_FROM=Da Enzo <info@da-enzo-muenchen.de>
NOTIFY_EMAIL=booking@da-enzo-muenchen.de
ADMIN_URL=https://www.da-enzo-muenchen.de

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin Setup (nur beim ersten Start relevant)
ADMIN_EMAIL=admin@da-enzo-muenchen.de
ADMIN_PASSWORD=BITTE_AENDERN
